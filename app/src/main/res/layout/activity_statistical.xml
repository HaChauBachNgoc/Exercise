<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B1831"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📊 NHẬT KÝ"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- 1. THANH CHỌN THỨ TRONG TUẦN -->
        <LinearLayout
            android:id="@+id/layoutWeekPicker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Điều hướng Tuần trước / Tuần sau -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <ImageButton
                    android:id="@+id/btnPrevWeek"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentStart="true"
                    android:background="@android:color/transparent"
                    android:contentDescription="Tuần trước"
                    android:src="@android:drawable/ic_media_previous"
                    app:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/txtCurrentRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Tuần này"
                    android:textColor="#BDBDBD"
                    android:textSize="13sp" />

                <ImageButton
                    android:id="@+id/btnNextWeek"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:background="@android:color/transparent"
                    android:contentDescription="Tuần sau"
                    android:src="@android:drawable/ic_media_next"
                    app:tint="#FFFFFF" />
            </RelativeLayout>

            <!-- Hàng các nút T2 -> CN tròn -->
            <RadioGroup
                android:id="@+id/rgDaysOfWeek"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:gravity="center"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbT2"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="3dp"
                    android:background="@drawable/selector_day_circle"
                    android:button="@null"
                    android:gravity="center"
                    android:text="T2"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/rbT3"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="3dp"
                    android:background="@drawable/selector_day_circle"
                    android:button="@null"
                    android:gravity="center"
                    android:text="T3"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/rbT4"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="3dp"
                    android:background="@drawable/selector_day_circle"
                    android:button="@null"
                    android:gravity="center"
                    android:text="T4"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/rbT5"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="3dp"
                    android:background="@drawable/selector_day_circle"
                    android:button="@null"
                    android:gravity="center"
                    android:text="T5"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/rbT6"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="3dp"
                    android:background="@drawable/selector_day_circle"
                    android:button="@null"
                    android:gravity="center"
                    android:text="T6"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/rbT7"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="3dp"
                    android:background="@drawable/selector_day_circle"
                    android:button="@null"
                    android:gravity="center"
                    android:text="T7"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/rbCN"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="3dp"
                    android:background="@drawable/selector_day_circle"
                    android:button="@null"
                    android:checked="true"
                    android:gravity="center"
                    android:text="CN"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </RadioGroup>
        </LinearLayout>

        <!-- 2. FORM NHẬP THỦ CÔNG CHI TIẾT THEO NGÀY ĐƯỢC CHỌN -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#2A2345"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- HIỂN THỊ NGÀY ĐANG CHỌN -->
                <TextView
                    android:id="@+id/txtSelectedDateTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📝 Nhật ký ngày: --/--/----"
                    android:textColor="#9B6DFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- MỤC 1: THỨC ĂN & CALO NẠP -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="🥗 Thực đơn &amp; Ăn uống"
                    android:textColor="#4CAF50"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtInputFoodName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="4dp"
                    android:background="#1B1831"
                    android:hint="Tên món ăn (Ví dụ: Cơm tấm, Phở bò...)"
                    android:importantForAutofill="no"
                    android:inputType="textPersonName"
                    android:padding="10dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/edtInputCaloIn"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:background="#1B1831"
                        android:hint="Calo nạp (kcal)"
                        android:importantForAutofill="no"
                        android:inputType="number"
                        android:padding="10dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#888888" />

                    <EditText
                        android:id="@+id/edtInputWeightLog"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:background="#1B1831"
                        android:hint="Cân nặng (kg)"
                        android:importantForAutofill="no"
                        android:inputType="numberDecimal"
                        android:padding="10dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#888888" />
                </LinearLayout>

                <!-- MỤC 2: VẬN ĐỘNG & CALO TIÊU -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="🏃‍♂️ Vận động &amp; Tập luyện"
                    android:textColor="#FF5C5C"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtInputExerciseName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="4dp"
                    android:background="#1B1831"
                    android:hint="Tên bài tập (Ví dụ: Chạy bộ, Gym...)"
                    android:importantForAutofill="no"
                    android:inputType="textPersonName"
                    android:padding="10dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/edtInputExercise"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:background="#1B1831"
                        android:hint="Thời gian (Phút)"
                        android:importantForAutofill="no"
                        android:inputType="number"
                        android:padding="10dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#888888" />

                    <EditText
                        android:id="@+id/edtInputCaloOut"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:background="#1B1831"
                        android:hint="Calo tiêu (kcal)"
                        android:importantForAutofill="no"
                        android:inputType="number"
                        android:padding="10dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#888888" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnSaveLog"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="#9B6DFF"
                    android:text="Lưu Nhật Ký Ngày"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 3. BẢNG TỔNG HỢP THỐNG KÊ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="📈 Bảng Thống Kê Tuần"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="#2A2345"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtStatCaloIn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🥗 Tổng Calo nạp: 0 kcal"
                    android:textColor="#4CAF50"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/txtStatCaloOut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="🔥 Tổng Calo tiêu: 0 kcal"
                    android:textColor="#FF5C5C"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/txtStatExercise"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="🏃‍♂️ Tổng thời gian vận động: 0 phút"
                    android:textColor="#4DA3FF"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/txtStatWeight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="⚖ Cân nặng trung bình: 0 kg"
                    android:textColor="#A875FF"
                    android:textSize="15sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <!-- ================= BOTTOM NAVIGATION ================= -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#2A2345"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- Hôm nay (Bình thường - Trắng) -->
                <LinearLayout
                    android:id="@+id/menuHome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@android:drawable/ic_menu_today"
                        app:tint="#FFFFFF"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hôm nay"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Nhật ký (Được chọn - Sáng Tím) -->
                <LinearLayout
                    android:id="@+id/menuDiary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="#9B6DFF"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nhật ký"
                        android:textColor="#9B6DFF"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Thống kê (Bình thường - Trắng) -->
                <LinearLayout
                    android:id="@+id/menuStatistic"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        app:tint="#FFFFFF"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thống kê"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Hồ sơ (Bình thường - Trắng) -->
                <LinearLayout
                    android:id="@+id/menuProfile"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="#FFFFFF"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hồ sơ"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>
                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>